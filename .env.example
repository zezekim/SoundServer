# SoundServer configuration — copy to `.env` and fill in real values.
# `.env` is git-ignored; never commit real secrets.

# ── Sound Server (flask-env/app.py, port 5000) ──────────────────────────
# Flask session signing key. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string
# API key exposed to the dashboard / HTTP clients.
DEFAULT_API_KEY=change-me-to-a-random-api-key
# Absolute paths (defaults suit the original Raspberry Pi deployment).
SOUND_FOLDER=/home/rs/flask-env/wav
TTS_CACHE_FOLDER=/home/rs/flask-env/tts_cache
SOUND_SERVER_PORT=5000

# ── Call Intercom (call/call.py, port 5020) ─────────────────────────────
CALL_FLASK_SECRET_KEY=change-me-to-another-long-random-string
CALL_SERIAL_PORT=/dev/ttyS0
CALL_BAUD_RATE=115200
CALL_WEB_PORT=5020

# ── SMS Gateway (sms/sms.py, port 5010) ─────────────────────────────────
SMS_SERIAL_PORT=/dev/ttyS0
SMS_BAUD_RATE=115200
SMS_WEB_PORT=5010
# SIM PIN, if the SIM is locked (leave blank if none).
SMS_PIN_CODE=
# Override the SIM's reported number in the UI (leave blank to auto-detect).
SMS_PHONE_NUMBER=
